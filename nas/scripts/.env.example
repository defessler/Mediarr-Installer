# ══════════════════════════════════════════════════════════════════════════════
# Media Stack — Environment Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit actual secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ── Service selection ─────────────────────────────────────────────────────────
# Per-service opt-out flags. Default-on: leave blank / unset / set to "true"
# to install that service; set to false / 0 / no / off (any case) to skip it.
# setup.sh maps these to COMPOSE_PROFILES so `docker compose up -d` only
# starts what you asked for. Prowlarr + Flaresolverr are always on (cheap,
# Prowlarr is the indexer manager every arr needs).
ENABLE_PLEX=true
ENABLE_SONARR=true
ENABLE_RADARR=true
ENABLE_LIDARR=true
ENABLE_BAZARR=true
ENABLE_QBITTORRENT=true
ENABLE_SABNZBD=true
ENABLE_HOMEPAGE=true
ENABLE_RECYCLARR=true
ENABLE_UNPACKERR=true
# FlareSolverr = CloudFlare bypass for Prowlarr's protected indexers. Default-on,
# but the wizard turns it OFF on arm64 hosts (it's upstream-deprecated and its
# bundled Chromium crashes on ARM). Disabling it only affects CloudFlare-gated
# indexer searches; everything else works.
ENABLE_FLARESOLVERR=true

# Soulseek is OPT-IN (default OFF) — the ONLY exception to the default-on
# rule above. Unlike every other service, a MISSING ENABLE_SOULSEEK key
# counts as OFF, and you must set it to true / 1 / yes / on explicitly to
# install it. slskd routes through the VPN (gluetun) like qBittorrent;
# soularr bridges Lidarr ↔ slskd for music. Requires ENABLE_LIDARR=true.
ENABLE_SOULSEEK=false

# AzuraCast is OPT-IN (default OFF), same rule as Soulseek above: a MISSING
# ENABLE_AZURACAST key counts as OFF — you must set it to true / 1 / yes / on
# explicitly to install it. It's a HEAVIER service (~1.4 GB image, wants
# 2–4 GB RAM): a self-contained internet-radio station builder that streams
# 24/7 "stations" from your music library. Web UI at http://<LAN_IP>:49157.
# See the AzuraCast section below, and https://github.com/defessler/Mediarr-Installer/wiki/Music-Radio
ENABLE_AZURACAST=false

# Playlist Sync is OPT-IN (default OFF), same rule as Soulseek/AzuraCast above:
# a MISSING ENABLE_PLAYLIST_SYNC key counts as OFF — set it to true / 1 / yes /
# on explicitly to install it. It mirrors SiriusXM channels + public Spotify
# playlists into your Music library as Plex OR Jellyfin playlists, downloading
# each track Soulseek-first (its own 2nd account) with a yt-dlp fallback. Routes
# through the VPN like Soulseek. Works with either media server (Jellyfin needs a
# JELLYFIN_API_KEY). See the Playlist Sync section below.
ENABLE_PLAYLIST_SYNC=false
# Music Videos is OPT-IN (default OFF). Set to true / 1 / yes / on to enable
# a cron-scheduled yt-dlp downloader that fills a dedicated Music Videos
# library browsable in Plex ("Other Videos" type) or Jellyfin ("Music Videos"
# type). Uses the bridge network — NOT the VPN — because YouTube blocks VPN
# IPs. See the Music Videos section below.
ENABLE_MUSIC_VIDEOS=false

# ── TRaSH Guide profile picks ──────────────────────────────────────────────────
# Which TRaSH Guide quality profile + custom-format bundle Recyclarr should
# sync into Sonarr / Radarr. The wizard's Configure screen sets these; the
# `recyclarr sync` step in setup-arr-config.py reads them to build
# recyclarr.yml's `include:` block. Hand-edit recyclarr.yml afterwards if you
# need something custom — these picks just seed it.
#   Sonarr: web-1080p | web-2160p | bluray-1080p | bluray-2160p | anime
#   Radarr: hd-bluray-web | uhd-bluray-web | remux-web-2160p | anime
TRASH_SONARR_PROFILE=web-1080p
TRASH_RADARR_PROFILE=hd-bluray-web

# ── Paths (NAS-family-portable) ───────────────────────────────────────────────
# Where the wizard installs its compose stack (config dirs for every container
# live under this) and where your media + downloads tree lives. The wizard's
# docker-compose.yml references both. Defaults per family:
#   Synology: /volume1/docker/media + /volume1/Data
#   Unraid:   /mnt/user/appdata/mediarr + /mnt/user/data
#   QNAP:     /share/Container/mediarr + /share/Data
#   TrueNAS:  /mnt/<pool>/apps/mediarr + /mnt/<pool>/data
#   Linux:    /opt/mediarr + /srv/data
# setup.sh requires DATA_ROOT (refuses to run without it). INSTALL_DIR is
# auto-filled from the script's own directory if missing.
INSTALL_DIR=
DATA_ROOT=

# ── System ────────────────────────────────────────────────────────────────────
# Run: id <your-username>  on the NAS to find these values
PUID=
PGID=
TZ=

# ── Network ───────────────────────────────────────────────────────────────────
# Your NAS LAN IP — all service ports bind to this address only
LAN_IP=

# Optional — host path to the Docker socket. Defaults to the standard
# /var/run/docker.sock (correct on Synology, UGREEN, QNAP, TrueNAS, Unraid,
# and most Linux Docker hosts). Override only on rootless Docker / Podman /
# non-standard setups, e.g. DOCKER_SOCK=/run/user/1000/docker.sock. Mounted
# read-only into Homepage and read-write into the Recyclarr trigger.
DOCKER_SOCK=

# Optional — your LAN subnet in CIDR. setup-firewall.sh derives this from
# LAN_IP as /24 by default (e.g. LAN_IP=192.168.50.42 → 192.168.50.0/24).
# Override only when your LAN isn't a /24 (e.g. LAN_SUBNET=10.0.0.0/16).
LAN_SUBNET=

# Optional — explicit Host header allow-list for Homepage dashboard.
# Default is `*` (any Host accepted) — fine for a home-LAN deployment.
# Set this to a comma-separated list of hostnames (no ports — Homepage
# strips them before comparison) only if you're fronting Homepage with
# a reverse proxy and want stricter Host validation. Example:
#   HOMEPAGE_ALLOWED_HOSTS=dashboard.home,192.168.1.10,nas.local
HOMEPAGE_ALLOWED_HOSTS=

# Optional — host disks to surface in the Homepage resources widget.
# setup.sh auto-populates these by scanning for /volume[0-9]+ dirs on
# Synology systems; on other platforms set them by hand to whatever
# you want monitored. docker-compose.yml's homepage service bind-mounts
# each MONITORED_DISK_N at /diskN:ro, and setup-arr-config.py renders
# a "disk" resources widget per populated slot. 4 slots, no widget if
# the slot is blank. Examples:
#   MONITORED_DISK_1=/volume1
#   MONITORED_DISK_2=/volume2
MONITORED_DISK_1=
MONITORED_DISK_2=
MONITORED_DISK_3=
MONITORED_DISK_4=

# ── Media server ──────────────────────────────────────────────────────────────
# Which media server to deploy: plex (default) or jellyfin. They're mutually
# exclusive — setup.sh activates the matching compose profile. ENABLE_PLEX
# (above) is the on/off master for the whole media-server group (server +
# request manager) regardless of which one you pick.
MEDIA_SERVER=plex
# Request-manager image. Jellyseerr (a superset fork that supports BOTH Plex
# and Jellyfin) is used for Jellyfin; Seerr for Plex. The wizard sets this to
# match MEDIA_SERVER; only override if you want a specific fork/tag.
SEERR_IMAGE=ghcr.io/seerr-team/seerr:latest

# ── Plex ──────────────────────────────────────────────────────────────────────
# Claim token from https://plex.tv/claim  (expires in 4 minutes)
# Only needed on first run — leave blank after the server is claimed.
# Ignored when MEDIA_SERVER=jellyfin.
PLEX_CLAIM=

# ── Jellyfin ──────────────────────────────────────────────────────────────────
# Only used when MEDIA_SERVER=jellyfin. Jellyfin has no claim token — after
# the stack is up, open http://<NAS>:8096, complete the first-run setup
# wizard, then go to Dashboard → API Keys → "+" to generate a key and paste
# it here. setup-arr-config.py uses it to wire Sonarr/Radarr/Lidarr library
# scans and the request manager. Leave blank to do that wiring manually later.
JELLYFIN_API_KEY=

# ── ARR Web UI Auth ───────────────────────────────────────────────────────────
# Credentials applied to Sonarr, Radarr, Lidarr, Prowlarr by setup-arr-config.py
# LAN connections bypass the login prompt automatically
ARR_USERNAME=
ARR_PASSWORD=

# ── ARR API Keys ──────────────────────────────────────────────────────────────
# Auto-discovered from each service's config.xml if left blank here.
# Fill in to skip auto-discovery or to override.
# After first boot: Settings → General → API Key in each service.
SONARR_API_KEY=
RADARR_API_KEY=
LIDARR_API_KEY=
PROWLARR_API_KEY=
SABNZBD_API_KEY=
BAZARR_API_KEY=
SEERR_API_KEY=

# ── qBittorrent ───────────────────────────────────────────────────────────────
# Set before first boot — applied via custom-cont-init.d script
QBITTORRENT_USER=admin
QBITTORRENT_PASS=

# ── Soulseek (slskd + soularr) ────────────────────────────────────────────────
# Only used when ENABLE_SOULSEEK=true (see Service selection above; it's
# opt-in). slskd runs INSIDE the VPN namespace (gluetun) just like
# qBittorrent; its WebUI is published at http://<LAN_IP>:5030. soularr
# watches Lidarr's wanted list and grabs matches off Soulseek into the
# shared download dir (${DATA_ROOT}/Downloads/Soulseek), which Lidarr
# then imports. Requires ENABLE_LIDARR=true.
#
# SLSKD_USER / SLSKD_PASS  — your free Soulseek account (the ONE thing you
#   provide; create it in the slskd web UI or the Soulseek desktop client).
# SLSKD_API_KEY            — INTERNAL secret between slskd and soularr, NOT a
#   Soulseek login. LEAVE BLANK: setup.sh auto-generates and saves one on the
#   first run (when Soulseek is on and this is empty). Only set it by hand to
#   pin a specific value.
# SOULARR_INTERVAL         — seconds between soularr scan cycles (default 300).
SLSKD_USER=
SLSKD_PASS=
SLSKD_API_KEY=
SOULARR_INTERVAL=300

# ── Playlist Sync (SiriusXM + Spotify → Plex / Jellyfin) ─────────────────────
# Only used when ENABLE_PLAYLIST_SYNC=true (opt-in; see Service selection above).
# A hands-off, recurring, track-for-track mirror: it reads each SiriusXM
# channel's rotation (free, via xmplaylist.com — no account) and each public
# Spotify playlist, downloads every track Soulseek-first with a yt-dlp fallback,
# and turns each into a playlist on your media server. Routes through the VPN
# like Soulseek. Works with Plex (play in Plexamp) OR Jellyfin (play in Finamp):
# on Jellyfin, set MEDIA_SERVER=jellyfin and put a Jellyfin API key (Dashboard ->
# API Keys, created after first-run setup) in JELLYFIN_API_KEY — the uploader
# skips cleanly until that key is set.
#
# PLAYLIST_SLSK_USER / PLAYLIST_SLSK_PASS — a SECOND free Soulseek account.
#   slskd already holds the stack's one Soulseek session and Soulseek allows
#   one session per account, so Playlist Sync needs its own login (2-min signup
#   in the Soulseek desktop client). REQUIRED when this feature is on.
# SIRIUSXM_CHANNELS — comma list of xmplaylist channel slugs, e.g.
#   octane,altnation,siriusxmhits1. A friendly guess is resolved if possible
#   (e.g. "hits1" → "siriusxmhits1"). Browse slugs at https://xmplaylist.com.
# SPOTIFY_PLAYLISTS — comma list of Spotify playlist URLs. Each entry may be a
#   bare URL (the Plex playlist is named "Spotify - <id>") or "Label|URL" to set
#   a friendly title. The installer's "Connect Spotify" button fills this in for
#   you from your account (private playlists included); or paste public URLs by
#   hand. (At least one of SIRIUSXM_CHANNELS / SPOTIFY_PLAYLISTS must be set.
#   SiriusXM is the fully-free, no-account path; Spotify needs the dev app below.)
# SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET — REQUIRED if you list any Spotify
#   playlists. sockseek needs your OWN free Spotify Developer app for ALL Spotify
#   inputs, INCLUDING public ones — create one at developer.spotify.com/dashboard
#   → Create app, set the Redirect URI to http://127.0.0.1:48721/callback, then
#   paste its Client ID + Secret here (the wizard's Connect flow uses them too).
#   NOTE: sockseek's docs state the app-owner account may need Spotify Premium —
#   so the Spotify half is NOT guaranteed subscription-free. Leave SPOTIFY_PLAYLISTS
#   empty to skip Spotify and use the fully-free SiriusXM path only.
# SPOTIFY_REFRESH_TOKEN — OPTIONAL; set automatically by the wizard's "Connect
#   Spotify" sign-in so the downloader can read your PRIVATE playlists. Leave
#   blank if you only sync public playlists.
# PLAYLIST_SYNC_CRON — schedule in cron form (default daily 4am: 0 4 * * *).
# PLAYLIST_PREF_FORMAT — preferred audio format (default flac; e.g. mp3).
# PLAYLIST_RUN_ON_START — run one pass when the container starts (default true)
#   so enabling the feature shows results without waiting for the first tick.
# PLAYLIST_SXM_DAYS / PLAYLIST_SXM_MIN_PLAYS — SiriusXM rotation window in days
#   and minimum play-count floor (defaults: 7 days, all tracks). Optional.
# PLAYLIST_MONTHLY_ARCHIVE — also keep a PERMANENT monthly "best of" per SiriusXM
#   station: "<station> (YYYY-MM)" with that month's top 50 by play count, frozen
#   forever once the month ends. Default true; set false to disable. (Each
#   archived month keeps its own copy of its tracks, so disk grows over time.)
PLAYLIST_SLSK_USER=
PLAYLIST_SLSK_PASS=
SIRIUSXM_CHANNELS=
SPOTIFY_PLAYLISTS=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
PLAYLIST_SYNC_CRON=0 4 * * *
PLAYLIST_PREF_FORMAT=flac
PLAYLIST_RUN_ON_START=true
PLAYLIST_SXM_DAYS=
PLAYLIST_SXM_MIN_PLAYS=
PLAYLIST_MONTHLY_ARCHIVE=true

# ── AzuraCast (broadcast radio) ───────────────────────────────────────────────
# Only used when ENABLE_AZURACAST=true (see Service selection above; it's
# opt-in). AzuraCast is a HEAVY, all-in-one internet-radio platform — it
# bundles its own MariaDB, Redis, Nginx and Liquidsoap in one ~1.4 GB image
# and wants 2 GB RAM minimum (4 GB comfortable). Plan for it before enabling.
#
# Unlike Plexamp's auto-generated stations, AzuraCast builds REAL 24/7
# broadcast stations ("The Pulse", "Chill", "90s") with AutoDJ, crossfades
# and live Icecast streams that anyone on your LAN can tune into. The
# installer stands the container up and wires it in; YOU build the actual
# stations in AzuraCast's own web UI (just like you set up Plex).
#
# AZURACAST_HTTP_PORT — the web UI / admin port, published bound to
#   ${LAN_IP}:49157 (remaps the host side only; the container listens on
#   AzuraCast's native port 80). First run: open http://<LAN_IP>:49157 and
#   create the admin account. (Stream ports are 8000–8029.)
# Your music library is mounted READ-ONLY at /mnt/music inside the container
#   (it's ${DATA_ROOT}/Media/Music — the same library Lidarr fills). Add a
#   Storage Location pointing at /mnt/music and assign a station to it.
# AzuraCast runs as UID/GID 1000 (its OWN — it does NOT honor PUID/PGID).
# Full walkthrough: https://github.com/defessler/Mediarr-Installer/wiki/Music-Radio
AZURACAST_HTTP_PORT=49157

# ── Music Videos ──────────────────────────────────────────────────────────────
# Cron-scheduled yt-dlp downloader that fills a dedicated Music Videos library
# browsable in Plex ("Other Videos" library type) or Jellyfin ("Music Videos"
# library type). Files are stored at ${DATA_ROOT}/Media/Music Videos with the
# layout: <Artist>/<Artist> - <Title>.mp4.
#
# Uses the BRIDGE network (NOT the VPN) — YouTube blocks datacenter/VPN IPs.
# Music videos are public content; no VPN is needed for this service.
#
# MUSIC_VIDEO_SOURCES — comma or newline-separated list of sources. Two forms:
#   "Artist | URL"  explicit artist name + a channel/playlist/video URL.
#                   All downloads filed under that artist. Best for single-
#                   artist VEVO channels, Topic channels, or playlists.
#   "URL"           bare URL — artist derived per-video from yt-dlp metadata
#                   (artist → album_artist → creator → uploader). Works well
#                   on VEVO / YouTube Music / "Topic" channels which carry
#                   real metadata; may produce "Various Artists" on generic
#                   channels.
#   Examples:
#     MUSIC_VIDEO_SOURCES=Metallica | https://www.youtube.com/@MetallicaTV,Tool | https://www.youtube.com/@Tool
#
# MUSIC_VIDEO_CRON — when to run the download pass (standard 5-field cron).
#   Default: daily at 04:00 (0 4 * * *).
#
# After enabling, create the library once in your media server:
#   Plex:     Add Library → Other Videos → ${DATA_ROOT}/Media/Music Videos
#   Jellyfin: Add Library → Music Videos  → ${DATA_ROOT}/Media/Music Videos
MUSIC_VIDEO_SOURCES=
MUSIC_VIDEO_CRON=0 4 * * *

# ── SABnzbd Usenet Provider ───────────────────────────────────────────────────
# Optional. Used by setup-arr-config.py to add a news server to SABnzbd
# automatically. Leave blank to skip; you can always add servers later
# at http://<NAS>:49155 → Config → Servers.
# Common providers: news.giganews.com (563), news.eweka.nl (563),
# ssl.frugalusenet.com (563), news.usenetserver.com (563)
USENET_HOST=
USENET_PORT=563
USENET_USER=
USENET_PASS=
USENET_CONNECTIONS=8
USENET_SSL=1
USENET_NAME=primary

# ── VPN ───────────────────────────────────────────────────────────────────────
# VPN is off by default. Flip to VPN_ENABLED=true to route qBittorrent
# through gluetun. When false, setup.sh applies docker-compose.no-vpn.yml
# and qBittorrent runs on the regular bridge network — your real public
# IP will be visible to torrent peers.
#
# Supported providers: nordvpn | protonvpn | mullvad | airvpn | surfshark | custom
# NordVPN access token: my.nordaccount.com → Manual setup → Access Tokens
# (setup-nordvpn.sh fetches NORDVPN_PRIVATE_KEY from the token automatically)
VPN_ENABLED=false
VPN_PROVIDER=nordvpn
VPN_TYPE=wireguard
NORDVPN_ACCESS_TOKEN=
NORDVPN_PRIVATE_KEY=
VPN_COUNTRIES=United States

# WireGuard config for non-NordVPN providers (ProtonVPN, Mullvad, AirVPN).
# Paste from the provider's WireGuard config download.
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
WIREGUARD_PRESHARED_KEY=

# OpenVPN credentials (only when VPN_TYPE=openvpn).
OPENVPN_USER=
OPENVPN_PASSWORD=

# VPN port forwarding. Set to "on" if your provider supports it AND you
# want qBittorrent's listen port routed back through the tunnel for
# better seeding. Supported: ProtonVPN, PIA, PrivateVPN, Perfect Privacy.
# NOT supported by NordVPN — leave at "off" or accept lower seed ratio.
VPN_PORT_FORWARDING=off

# ── Usenet Indexers ───────────────────────────────────────────────────────────
# Used by setup-indexers.py
# AnimeTosho is added automatically (free, no key needed).
# AnimeTosho also accepts an optional API key for higher rate limits.
# All others require an account — leave blank to skip.
ANIMETOSHO_API_KEY=      # animetosho.org → Account → API Key  (optional, increases limits)
NZBGEEK_API_KEY=         # nzbgeek.info       → Profile → API Key
NZBFINDER_API_KEY=       # nzbfinder.ws        → Profile → API Key
DRUNKENSLUG_API_KEY=     # drunkenslug.com     → Account → API Key  (invite-only)
NZBPLANET_API_KEY=       # nzbplanet.net       → Account → API Key
NZBCAT_API_KEY=          # nzb.cat             → Account → API Key
DOGNZB_API_KEY=          # dognzb.cr           → Profile → API Key  (invite-only)
NINJACZENTRAL_API_KEY=   # ninjacentral.co.za  → Profile → API Key
TABULARASA_API_KEY=      # tabula-rasa.pw      → Profile → API Key
NZBSU_API_KEY=           # nzb.su              → Profile → API Key

# ── Private Torrent Trackers ──────────────────────────────────────────────────
# Used by setup-indexers.py — leave blank to skip
# AvistaZ:       best source for Korean/Asian movies and TV  (apply at avistaz.to)
#                PID is the "passkey" on your AvistaZ profile page; required.
# HHD:           Korean movies/dramas — register at homiehelpdesk.net → API Key
# AnimeBytes:    highest quality anime  (invite-only)
# AnimeTorrents: good anime tracker  (application-based)
# IPTorrents:    general-purpose private tracker  (invite-based)
#                Cookie-only auth: log in in your browser, DevTools →
#                Application → Cookies → iptorrents.com → copy the
#                entire cookie string (uid=...; pass=...; ...).
# RuTracker:     huge Russian general tracker — deep music / discography
#                coverage. Free account (the signup form is in Russian).
#                CloudFlare-gated, so it auto-routes through FlareSolverr
#                (which the installer disables on arm64 — no RuTracker there).
AVISTAZ_USER=
AVISTAZ_PASS=
AVISTAZ_PID=
HHD_API_KEY=
ANIMEBYTES_USER=
ANIMEBYTES_PASS=
ANIMETORRENTS_USER=
ANIMETORRENTS_PASS=
IPTORRENTS_COOKIE=
RUTRACKER_USER=
RUTRACKER_PASS=

# ── Subtitle Providers ────────────────────────────────────────────────────────
# Used by setup-bazarr-providers.py — leave blank to skip that provider
# Free providers (YIFY, Podnapisi, etc.) are added automatically without credentials
OPENSUBTITLES_USER=      # opensubtitles.org   → free account
OPENSUBTITLES_PASS=
OPENSUBTITLESCOM_USER=   # opensubtitles.com   → free account (larger DB)
OPENSUBTITLESCOM_PASS=
ADDIC7ED_USER=           # addic7ed.com        → free account
ADDIC7ED_PASS=
