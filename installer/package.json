{
  "name": "mediarr-installer",
  "version": "0.5.0",
  "description": "Mediarr Installer — Electron wizard that installs the Arr media stack onto a Synology NAS over SSH",
  "main": "out/main/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-payload": "node scripts/copy-nas-payload.mjs",
    "dev": "npm run copy-payload && electron-vite dev",
    "dev:mock": "npm run copy-payload && cross-env INSTALLER_MOCK=1 electron-vite dev",
    "build": "npm run copy-payload && electron-vite build",
    "build:win": "npm run build && electron-builder --win --publish never",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "electron-log": "^5.2.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "ssh2": "^1.16.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.2"
  }
}
